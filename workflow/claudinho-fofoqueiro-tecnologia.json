          "name": "n8n free OpenAI API credits"
        }
      }
    },
    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "keywords = {\n    \"ai\": 3,\n    \"openai\": 3,\n    \"llm\": 3,\n    \"python\": 2,\n    \"javascript\": 2,\n    \"cloud\": 2,\n    \"automation\": 2,\n    \"startup\": 1,\n    \"developer\": 2,\n    \"security\": 2\n}\n\ncategorized = []\n\nfor item in _items:\n    article = item[\"json\"]\n    text = f'{article.get(\"title\", \"\")} {article.get(\"description\", \"\")}'.lower()\n\n    score = 0\n    for key, value in keywords.items():\n        if key in text:\n            score += value\n\n    category = \"Technology\"\n    if \"ai\" in text or \"openai\" in text or \"llm\" in text:\n        category = \"AI\"\n    elif \"python\" in text or \"javascript\" in text or \"developer\" in text:\n        category = \"Development\"\n    elif \"cloud\" in text:\n        category = \"Cloud\"\n    elif \"security\" in text:\n        category = \"Security\"\n    elif \"startup\" in text:\n        category = \"Startups\"\n\n    categorized.append({\n        \"json\": {\n            \"date\": article.get(\"publishedAt\", \"\")[:10],\n            \"title\": article.get(\"title\", \"\"),\n            \"description\": article.get(\"description\", \"\"),\n            \"source\": article.get(\"source\", \"\"),\n            \"publishedAt\": article.get(\"publishedAt\", \"\"),\n            \"relevance_score\": score,\n            \"category\": category,\n            \"url\": article.get(\"url\", \"\")\n        }\n    })\n\ncategorized.sort(key=lambda x: x[\"json\"][\"relevance_score\"], reverse=True)\n\nreturn categorized[:5]"
      },
